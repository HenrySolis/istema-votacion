# Variables de entorno del backend

# ── Base de datos PostgreSQL (Neon / Supabase / Railway) ─────
DATABASE_URL=postgresql://usuario:contraseña@host/dbname

# true en producción (Neon y similares lo requieren)
DB_SSL=true

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_seguro_min32
JWT_EXPIRES_IN=8h

# ── CORS: URL del frontend en Vercel (sin barra final) ───────
FRONTEND_URL=https://tu-proyecto.vercel.app

# ── Solo para desarrollo local ────────────────────────────────
PORT=3000
